#include<stdio.h>
#include<stdlib.h>
#include<string.h>
struct node
{
  char book[101];
  struct node *next;
};
struct node *top=NULL;

void push(char name[])
{
  struct node *newnode=(struct node*)malloc(sizeof(struct node));
  strcpy(newnode->book,name);
  newnode->next=top;
  top=newnode;
}

void Top()
{
  if(top==NULL)
  {
    printf("Stack Underflow\n");
    return;
  }
  printf("%s\n",top->book);
  
}

void pop()
{
  if(top==NULL)
  {
   printf("Stack Underflow\n");
   return;
  }
  struct node *temp=top;
  top=top->next;
  free(temp);
}

void isempty()
{
  if(top==NULL)
  {
    printf("true\n");
  }
  else
  {
    printf("false\n");
  }
}

void size()
{
  int count=0;
  struct node *temp=top;

  while(temp!=NULL)
  {
    count++;
    temp=temp->next;
  }
  printf("%d\n",count);
}
int main()
{
  int n;
  char input[20];
  char name[101];

  scanf("%d",&n);

  for(int i=0;i<n;i++)
  {
    scanf("%s",input);

    if(strcmp(input,"Push")==0)
    {
      scanf(" %[^\n]",name);
      push(name);
    }
    else if( strcmp(input,"Pop")==0)
    {
     pop();
    }
    else if(strcmp(input,"Top")==0)
    {
      Top();
    }
    else if(strcmp(input,"Size")==0)
    {
      size();
    }
    else if(strcmp(input,"IsEmpty")==0)
    {
      isempty();
    }
  }
  return 0;
}
